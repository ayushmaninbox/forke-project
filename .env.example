# Database connection string (pre-configured for local Docker Compose setup)
DATABASE_URL="postgresql://forke:forke_secret@localhost:5433/forke_dev"

# NextAuth / Auth.js configuration
# Generate a new random secret using: npx auth secret
AUTH_SECRET="your_next_auth_secret_here"
AUTH_TRUST_HOST="true"
AUTH_URL="http://localhost:3000"

# Salt for one-way hashing IP addresses in the auth security log (auth_events).
# Use a long random value; rotating it invalidates old hash matches.
ANALYTICS_IP_SALT="change_me_to_a_long_random_string"

# Google Analytics 4 measurement ID. Only loads in production (NODE_ENV=production).
# Leave blank locally; set it in Vercel for the live site.
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Google OAuth Credentials (Get these from Google Cloud Console)
AUTH_GOOGLE_ID="your_google_id_here"
AUTH_GOOGLE_SECRET="your_google_secret_here"

# GitHub OAuth Credentials (Get these from GitHub Developer Settings)
AUTH_GITHUB_ID="your_github_id_here"
AUTH_GITHUB_SECRET="your_github_secret_here"

# AES-256-GCM key for encrypting file URLs in the database (64 hex chars = 32 bytes)
FILE_ENCRYPTION_KEY=your_64_char_hex_key_here

# Cloudflare R2 Storage Configurations
CLOUDFLARE_R2_ACCESS_KEY_ID="your_r2_access_key_id_here"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_r2_secret_access_key_here"
CLOUDFLARE_R2_ENDPOINT="https://your_cloudflare_account_id.r2.cloudflarestorage.com"
CLOUDFLARE_R2_BUCKET_NAME="your_r2_bucket_name_here"
CLOUDFLARE_R2_PUBLIC_URL="https://your_custom_r2_public_domain.com"
CLOUDFLARE_API_TOKEN="your_generated_bearer_token"

# Email (Resend)
RESEND_API_KEY="your_resend_api_key_here"
RESEND_AUDIENCE_ID="your_resend_audience_id_here"
